# ========================================
# Python 缓存
# ========================================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# ========================================
# 虚拟环境
# ========================================
.venv/
venv/
ENV/
env/

# ========================================
# IDE 配置
# ========================================
.idea/
.vscode/
*.swp
*.swo
*.swn
.project
.pydevproject
.settings/

# ========================================
# 环境变量（包含敏感信息）
# ========================================
.env
.env.local
.env.*.local

# ========================================
# 数据库和日志
# ========================================
*.db
*.sqlite
*.sqlite3
*.log
data/
# 思维簇系统模板（文档 + 默认模块 + 链配置）需要入库
!lumen/data/
!lumen/data/thinking_clusters/
!lumen/data/thinking_clusters/SPECIFICATION.md
!lumen/data/thinking_clusters/chains.json
!lumen/data/thinking_clusters/task_context/
!lumen/data/thinking_clusters/reasoning_patterns/
!lumen/data/thinking_clusters/self_correction/

# 运行时数据（用户日记、配置、缓存）
lumen/data/daily_note/
lumen/data/knowledge/daily_note/
lumen/data/runtime_config.json
lumen/data/tdb_registry.json
snapshot*.txt

# ========================================
# 用户个人数据（Persona / 世界书 / 角色 / Skills，只追踪 default 模板）
# ========================================
lumen/personas/*.json
lumen/worldbooks/*.json
lumen/characters/*.json
lumen/characters/avatars/
lumen/skills/*
!lumen/skills/README.md

# 前端公共资源（头像上传目录，运行时生成）
lumen-Front/public/avatars/

# ========================================
# 测试和覆盖率
# ========================================
.pytest_cache/
.coverage
htmlcov/
coverage.xml
*.cover
.hypothesis/
.tox/

# ========================================
# 类型检查
# ========================================
.mypy_cache/
.dmypy.json
dmypy.json
.pyre/
.pytype/

