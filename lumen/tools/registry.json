{
  "file_manager": {
    "description": "文件系统管理工具，支持读写文件、目录操作、搜索、编辑、复制移动等",
    "usage_guide": "所有文件/目录操作统一通过此工具完成。command 决定具体操作：read读文件、write写文件、edit精确替换、list列目录、glob搜文件名、grep搜文件内容、info查文件信息。搜索文件名用 glob，搜索文件内容用 grep。注意：当用户描述的路径不明确时，先用 list 查看父目录，确认实际路径名后再操作，不要猜测路径。",
    "commands": {
      "read": {
        "description": "读取文件内容（支持文本/图片/PDF），带行号",
        "parameters": {
          "type": "object",
          "properties": {
            "path": { "type": "string", "description": "文件路径" },
            "encoding": { "type": "string", "description": "文件编码，默认utf-8" },
            "offset": { "type": "integer", "description": "起始行号，默认1" },
            "limit": { "type": "integer", "description": "最大行数，默认2000" }
          },
          "required": ["path"]
        }
      },
      "list": {
        "description": "列出目录内容（表格形式，显示名称/类型/大小/时间）",
        "parameters": {
          "type": "object",
          "properties": {
            "path": { "type": "string", "description": "目录路径" }
          },
          "required": ["path"]
        }
      },
      "glob": {
        "description": "按文件名模式搜索文件（支持 **/*.py 等通配符）",
        "parameters": {
          "type": "object",
          "properties": {
            "path": { "type": "string", "description": "搜索根目录" },
            "pattern": { "type": "string", "description": "文件名模式，如 **/*.py" }
          },
          "required": ["path", "pattern"]
        }
      },
      "grep": {
        "description": "按正则表达式搜索文件内容",
        "parameters": {
          "type": "object",
          "properties": {
            "path": { "type": "string", "description": "搜索路径（文件或目录）" },
            "pattern": { "type": "string", "description": "正则表达式" },
            "case_sensitive": { "type": "boolean", "description": "区分大小写，默认false" }
          },
          "required": ["path", "pattern"]
        }
      },
      "info": {
        "description": "获取文件或目录的元信息（大小/类型/时间等）",
        "parameters": {
          "type": "object",
          "properties": {
            "path": { "type": "string", "description": "文件或目录路径" }
          },
          "required": ["path"]
        }
      },
      "write": {
        "description": "创建或覆盖文件（自动创建父目录，已有文件自动备份.bak）",
        "parameters": {
          "type": "object",
          "properties": {
            "path": { "type": "string", "description": "文件路径" },
            "content": { "type": "string", "description": "文件内容" },
            "encoding": { "type": "string", "description": "文件编码，默认utf-8" }
          },
          "required": ["path", "content"]
        }
      },
      "edit": {
        "description": "精确替换文件中的文本（SEARCH/REPLACE方式，old_string必须在文件中唯一）",
        "parameters": {
          "type": "object",
          "properties": {
            "path": { "type": "string", "description": "文件路径" },
            "old_string": { "type": "string", "description": "要替换的原始文本（必须精确匹配）" },
            "new_string": { "type": "string", "description": "替换后的新文本" },
            "encoding": { "type": "string", "description": "文件编码，默认utf-8" }
          },
          "required": ["path", "old_string", "new_string"]
        }
      },
      "append": {
        "description": "追加内容到文件末尾（文件不存在则创建）",
        "parameters": {
          "type": "object",
          "properties": {
            "path": { "type": "string", "description": "文件路径" },
            "content": { "type": "string", "description": "追加内容" },
            "encoding": { "type": "string", "description": "文件编码，默认utf-8" }
          },
          "required": ["path", "content"]
        }
      },
      "copy": {
        "description": "复制文件（目标已存在自动改名）",
        "parameters": {
          "type": "object",
          "properties": {
            "path": { "type": "string", "description": "源文件路径" },
            "destination": { "type": "string", "description": "目标路径" }
          },
          "required": ["path", "destination"]
        }
      },
      "move": {
        "description": "移动文件（目标已存在自动改名）",
        "parameters": {
          "type": "object",
          "properties": {
            "path": { "type": "string", "description": "源文件路径" },
            "destination": { "type": "string", "description": "目标路径" }
          },
          "required": ["path", "destination"]
        }
      },
      "rename": {
        "description": "重命名文件（目标已存在则拒绝覆盖）",
        "parameters": {
          "type": "object",
          "properties": {
            "path": { "type": "string", "description": "原文件路径" },
            "destination": { "type": "string", "description": "新文件名或路径" }
          },
          "required": ["path", "destination"]
        }
      },
      "delete": {
        "description": "删除文件到回收站（安全删除，不直接永久删除）",
        "parameters": {
          "type": "object",
          "properties": {
            "path": { "type": "string", "description": "文件路径" }
          },
          "required": ["path"]
        }
      },
      "mkdir": {
        "description": "创建目录（递归创建，类似 mkdir -p）",
        "parameters": {
          "type": "object",
          "properties": {
            "path": { "type": "string", "description": "目录路径" }
          },
          "required": ["path"]
        }
      },
      "download": {
        "description": "从URL下载文件到本地",
        "parameters": {
          "type": "object",
          "properties": {
            "path": { "type": "string", "description": "保存路径" },
            "url": { "type": "string", "description": "下载地址" }
          },
          "required": ["path", "url"]
        }
      }
    }
  },
  "web": {
    "description": "网络工具，支持互联网搜索、网页抓取和多页爬取",
    "usage_guide": "search搜索互联网获取实时信息，fetch抓取单个URL的网页正文，crawl从起始URL爬取多个关联页面（适合文档站、博客系列）。通常先search获取URL列表，再用crawl或fetch读取内容。",
    "commands": {
      "search": {
        "description": "搜索互联网获取实时信息",
        "parameters": {
          "type": "object",
          "properties": {
            "query": { "type": "string", "description": "搜索关键词" },
            "max_results": { "type": "integer", "description": "返回结果数量，默认5，最多10" }
          },
          "required": ["query"]
        }
      },
      "fetch": {
        "description": "抓取指定URL的网页内容并提取正文",
        "parameters": {
          "type": "object",
          "properties": {
            "url": { "type": "string", "description": "网页URL" },
            "max_length": { "type": "integer", "description": "返回内容最大字符数，默认5000" }
          },
          "required": ["url"]
        }
      },
      "crawl": {
        "description": "从起始URL爬取多个关联页面，适合文档站、博客系列等多页内容获取",
        "parameters": {
          "type": "object",
          "properties": {
            "url": { "type": "string", "description": "起始URL（必填）" },
            "max_pages": { "type": "integer", "description": "最大抓取页数，默认20，最多50" },
            "max_depth": { "type": "integer", "description": "最大链接深度，默认3，最多5" },
            "path_prefix": { "type": "string", "description": "只爬此路径前缀下的页面，如 /docs/" },
            "max_content_length": { "type": "integer", "description": "每页最大字符数，默认5000" },
            "max_total_length": { "type": "integer", "description": "总内容最大字符数，0=不限制，默认0" }
          },
          "required": ["url"]
        }
      }
    }
  },
  "calculate": {
    "description": "计算数学表达式的结果，支持加减乘除、幂运算、括号",
    "usage_guide": "用户需要数学计算时必须调用，不要自己心算。适合加减乘除、百分比、单位换算等场景。",
    "parameters": {
      "type": "object",
      "properties": {
        "expression": { "type": "string", "description": "数学表达式，例如 2+3*4 或 (100-20)/8" }
      },
      "required": ["expression"]
    }
  },
  "daily_note": {
    "description": "保存重要信息到日记/档案，跨会话可用",
    "usage_guide": "你有持久日记能力。以下情况应主动保存：\n- 用户偏好（\"我喜欢简洁回复\"、\"不要用emoji\"）\n- 重要约定（\"下次聊第三章\"）\n- 关键事实（\"我的项目叫XXX\"）\n- 决策记录（\"决定用方案B\"）\n\n不要保存：临时闲聊、已完成的任务进度、用户能看到的信息\n调用 daily_note 工具保存，自动打 tags 帮助未来检索。",
    "parameters": {
      "type": "object",
      "properties": {
        "content": { "type": "string", "description": "要记住的内容（用第三人称描述，如'用户喜欢简洁回复'）" },
        "tags": { "type": "array", "items": { "type": "string" }, "description": "标签（帮助未来检索）" },
        "importance": { "type": "integer", "description": "重要度 1-5（5最重要），默认3" },
        "category": { "type": "string", "description": "分类：preference/fact/context/decision，默认context" }
      },
      "required": ["content"]
    }
  },
  "dice": {
    "description": "掷骰子，支持标准骰子表达式",
    "usage_guide": "需要随机决定结果时使用。格式: NdS[+M]，如 2d6+3 掷2个6面骰加3，1d20 掷1个20面骰。",
    "parameters": {
      "type": "object",
      "properties": {
        "expression": { "type": "string", "description": "骰子表达式，如 1d20, 2d6+3, 3d8-1，默认 1d20" }
      },
      "required": []
    }
  },
  "rpg": {
    "description": "RPG 游戏动作工具：移动、检定、战斗",
    "usage_guide": "RPG 跑团专用。move_to 移动到新房间，roll_check 进行属性检定，resolve_attack 执行攻击判定。",
    "commands": {
      "move_to": {
        "description": "移动到指定房间（自动离开旧房间、加入新房间）",
        "parameters": {
          "type": "object",
          "properties": {
            "agent_id": { "type": "string", "description": "移动的 Agent ID（默认为当前角色）" },
            "room_id": { "type": "string", "description": "目标房间 ID" }
          },
          "required": ["room_id"]
        }
      },
      "roll_check": {
        "description": "属性检定：掷 1d20 + 属性修正 vs 难度等级",
        "parameters": {
          "type": "object",
          "properties": {
            "agent_id": { "type": "string", "description": "检定的 Agent ID（默认为当前角色）" },
            "attribute": { "type": "string", "description": "属性名（str/dex/con/int/wis/cha），默认 str" },
            "difficulty": { "type": "integer", "description": "难度等级 DC，默认 10" }
          },
          "required": []
        }
      },
      "resolve_attack": {
        "description": "战斗判定：攻击掷骰 → 命中 → 伤害 → HP 更新",
        "parameters": {
          "type": "object",
          "properties": {
            "attacker_id": { "type": "string", "description": "攻击者 ID（默认为当前角色）" },
            "target_id": { "type": "string", "description": "目标 ID 或名字" },
            "attack_attr": { "type": "string", "description": "攻击属性（默认 str）" },
            "defense_attr": { "type": "string", "description": "防御属性（默认 dex）" },
            "damage_dice": { "type": "string", "description": "伤害骰子表达式（默认 1d6）" }
          },
          "required": ["target_id"]
        }
      },
      "look": {
        "description": "查看当前房间：描述 + 实体列表",
        "parameters": {
          "type": "object",
          "properties": {
            "agent_id": { "type": "string", "description": "查看者 ID（默认为当前角色）" }
          },
          "required": []
        }
      }
    }
  },
  "theme": {
    "description": "主题系统控制工具，支持查看/切换/微调/保存视觉主题",
    "usage_guide": "通过 command 选择操作：list 列出所有主题、get 获取主题详情、apply 切换主题或微调 token、save 保存为新主题。微调时提供 tokens 对象，键为 token 名（如 primary、surfaceDeep），值为 CSS 值（如 #FF0000、8px）。",
    "commands": {
      "list": {
        "description": "列出所有可用主题",
        "parameters": { "type": "object", "properties": {}, "required": [] }
      },
      "get": {
        "description": "获取主题的全部 token 值",
        "parameters": {
          "type": "object",
          "properties": {
            "theme_id": { "type": "string", "description": "主题 ID，默认当前主题" }
          },
          "required": []
        }
      },
      "apply": {
        "description": "应用主题（切换/微调/生成）",
        "parameters": {
          "type": "object",
          "properties": {
            "theme_id": { "type": "string", "description": "目标主题 ID" },
            "tokens": {
              "type": "object",
              "description": "Token 键值对",
              "additionalProperties": { "type": "string" }
            }
          }
        }
      },
      "save": {
        "description": "保存当前主题为新主题",
        "parameters": {
          "type": "object",
          "properties": {
            "name": { "type": "string", "description": "新主题显示名" },
            "description": { "type": "string", "description": "主题描述" }
          },
          "required": ["name"]
        }
      }
    }
  },
  "chrome_bridge": {
    "description": "通过 Chrome 浏览器扩展浏览和控制网页：导航到URL、获取页面快照/截图/HTML/文本、点击元素、输入文本、执行JS脚本",
    "usage_guide": "Chrome Bridge 让你能像真人一样浏览网页。使用前确保：1) Chrome 已安装 Lumen Chrome Bridge 扩展；2) 扩展图标显示绿色'ON'。主要命令：navigate 导航到URL并返回页面快照、snapshot 获取a11y树快照（按钮/输入框/链接等可交互元素）、screenshot 截取页面可见区域PNG截图、get_html 获取原始HTML用于分析DOM和CSS结构、get_text 提取纯文本内容、click 点击元素并返回新快照、type 输入文本、evaluate 执行JS脚本、scroll 滚动页面、chain 串行执行多个命令。分析网页布局时用 screenshot看外观+get_html看结构+snapshot看元素。",
    "commands": {
      "navigate": {
        "description": "导航到指定URL，等待页面加载完成后返回页面快照（a11y树）",
        "parameters": {
          "type": "object",
          "properties": {
            "command": { "type": "string", "description": "固定为 navigate" },
            "url": { "type": "string", "description": "要导航到的完整URL地址" }
          },
          "required": ["command", "url"]
        }
      },
      "snapshot": {
        "description": "获取当前页面 a11y 无障碍树快照，包含可交互元素及其位置",
        "parameters": {
          "type": "object",
          "properties": {
            "command": { "type": "string", "description": "固定为 snapshot" }
          },
          "required": ["command"]
        }
      },
      "screenshot": {
        "description": "截取当前页面可见区域的PNG截图（返回base64 data URL）",
        "parameters": {
          "type": "object",
          "properties": {
            "command": { "type": "string", "description": "固定为 screenshot" }
          },
          "required": ["command"]
        }
      },
      "click": {
        "description": "点击指定元素（按钮/链接），等待页面变化后返回新快照",
        "parameters": {
          "type": "object",
          "properties": {
            "command": { "type": "string", "description": "固定为 click" },
            "target": { "type": "string", "description": "按钮/链接的文字内容或描述" },
            "selector": { "type": "string", "description": "CSS选择器（可选，优先级高于target）" }
          },
          "required": ["command"]
        }
      },
      "type": {
        "description": "在输入框中输入文本，等待页面响应后返回新快照",
        "parameters": {
          "type": "object",
          "properties": {
            "command": { "type": "string", "description": "固定为 type" },
            "text": { "type": "string", "description": "要输入的文本" },
            "target": { "type": "string", "description": "输入框的文字/placeholder描述" },
            "selector": { "type": "string", "description": "CSS选择器（可选，优先级高于target）" }
          },
          "required": ["command", "text"]
        }
      },
      "evaluate": {
        "description": "在当前页面执行JavaScript脚本并返回结果",
        "parameters": {
          "type": "object",
          "properties": {
            "command": { "type": "string", "description": "固定为 evaluate" },
            "text": { "type": "string", "description": "JavaScript 代码（可访问DOM和全局变量）" }
          },
          "required": ["command", "text"]
        }
      },
      "scroll": {
        "description": "滚动页面（up/down），返回新快照",
        "parameters": {
          "type": "object",
          "properties": {
            "command": { "type": "string", "description": "固定为 scroll" },
            "text": { "type": "string", "description": "滚动方向：up 或 down，默认 down" }
          },
          "required": ["command"]
        }
      },
      "get_html": {
        "description": "获取当前页面的原始HTML（可指定CSS选择器限定范围），用于分析DOM结构和CSS class",
        "parameters": {
          "type": "object",
          "properties": {
            "command": { "type": "string", "description": "固定为 get_html" },
            "selector": { "type": "string", "description": "CSS选择器限定范围（可选，默认整个页面）" }
          },
          "required": ["command"]
        }
      },
      "get_text": {
        "description": "提取当前页面的纯文本内容（可指定CSS选择器限定范围），用于分析文本和内容结构",
        "parameters": {
          "type": "object",
          "properties": {
            "command": { "type": "string", "description": "固定为 get_text" },
            "selector": { "type": "string", "description": "CSS选择器限定范围（可选，默认body）" }
          },
          "required": ["command"]
        }
      },
      "chain": {
        "description": "串行执行多个命令（适合需要先点击再填表等复合操作），返回最后一个命令的结果",
        "parameters": {
          "type": "object",
          "properties": {
            "command": { "type": "string", "description": "固定为 chain" },
            "commands": {
              "type": "array",
              "description": "命令列表，每个命令包含 command/url/target/text/selector",
              "items": {
                "type": "object",
                "properties": {
                  "command": { "type": "string" },
                  "url": { "type": "string" },
                  "target": { "type": "string" },
                  "text": { "type": "string" },
                  "selector": { "type": "string" }
                }
              }
            }
          },
          "required": ["command", "commands"]
        }
      }
    }
  }
}
