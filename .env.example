# Lumen 配置文件模板
# 复制此文件为 .env 并填入你的真实配置

# API地址 - 这是本地代理，转发到各个LLM服务商
API_URL=http://127.0.0.1:4000/v1

# API密钥（请替换为你的真实密钥）
API_KEY=your-api-key-here

# 默认使用的模型
MODEL=deepseek-chat
# 搜索代理（国内访问 DuckDuckGo 需要，填你的代理地址和端口）
SEARCH_PROXY=http://127.0.0.1:7897

# 网页抓取代理（抓取国外网页时可能需要，留空则不走代理）
FETCH_PROXY=http://127.0.0.1:7897
